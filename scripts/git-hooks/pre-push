#!/usr/bin/env bash
# Последний барьер перед публикацией: сканирует ВСЮ отправляемую историю (все блобы в диапазоне),
# поэтому ловит дамп даже если он был добавлен и удалён внутри тех же коммитов.
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$HERE/_guard.sh"

z40="0000000000000000000000000000000000000000"
bad=""

while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$z40" ] && continue           # удаление ветки — пропускаем
  if [ "$remote_sha" = "$z40" ]; then
    objs="$(git rev-list --objects "$local_sha" --not --remotes 2>/dev/null || git rev-list --objects "$local_sha")"
  else
    objs="$(git rev-list --objects "$remote_sha..$local_sha")"
  fi
  [ -z "$objs" ] && continue
  paths="$(printf '%s\n' "$objs" | awk 'NF>1{$1="";sub(/^ /,"");print}')"
  hit="$(printf '%s\n' "$paths" | forbidden_paths | sort -u)"
  [ -n "$hit" ] && bad+="$hit"$'\n'
done

bad="$(printf '%s' "$bad" | sed '/^$/d' | sort -u)"
[ -z "$bad" ] && exit 0

{
  echo "🚫 PUSH ЗАБЛОКИРОВАН — в отправляемой истории есть чувствительные файлы:"
  printf '%s\n' "$bad" | sed 's/^/  • /'
  echo
  echo "Эти данные попали бы в публичную историю GitHub (так и случилась утечка дампов БД)."
  echo "Вычистите их из истории перед пушем: git filter-repo / filter-branch, затем повторите."
  echo "Осознанный обход: git push --no-verify  (крайне не рекомендуется)"
} >&2
exit 1
